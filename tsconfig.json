{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@core/*": [".\/src\/core\/*"],
      "@grudge/*": [".\/src\/grudge\/*"],
      "@scenes/*": [".\/src\/scenes\/*"]
    }
  },
  "include": ["src"]
}
