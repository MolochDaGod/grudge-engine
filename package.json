{
  "name": "grudge-engine",
  "version": "0.1.0",
  "description": "Grudge Engine — Babylon.js game component library powered by Grudge Studio",
  "author": "Racalvin The Pirate King",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "server": "node server/index.js",
    "server:dev": "node --watch server/index.js",
    "start": "npm run build && node server/index.js",
    "dev:full": "concurrently \"npm run dev\" \"npm run server:dev\""
  },
  "dependencies": {
    "@babel/traverse": "^7.29.0",
    "@babylonjs/accessibility": "^9.0.0",
    "@babylonjs/addons": "^9.0.0",
    "@babylonjs/core": "^9.0.0",
    "@babylonjs/gui": "^9.0.0",
    "@babylonjs/havok": "^1.3.12",
    "@babylonjs/inspector": "^9.0.0",
    "@babylonjs/ktx2decoder": "^9.0.0",
    "@babylonjs/loaders": "^9.0.0",
    "@babylonjs/materials": "^9.0.0",
    "@babylonjs/post-processes": "^9.0.0",
    "@babylonjs/procedural-textures": "^9.0.0",
    "@babylonjs/serializers": "^9.0.0",
    "@babylonjs/viewer": "^9.0.0",
    "@shaderfrog/glsl-parser": "^7.0.1",
    "@xterm/addon-attach": "^0.12.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "babel-traverse": "^6.26.0",
    "bitecs": "^0.4.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "howler": "^2.2.4",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.1.0",
    "recast-detour": "^1.6.4",
    "recast-navigation": "^0.43.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "spectorjs": "^0.9.30",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.28.0",
    "@types/howler": "^2.2.12",
    "@types/socket.io-client": "^1.4.36",
    "concurrently": "^9.2.1",
    "puppeteer": "^24.40.0",
    "sharp": "^0.34.5",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
