{
  "name": "grudge-engine",
  "version": "0.1.0",
  "description": "Grudge Engine — Babylon.js game component library powered by Grudge Studio",
  "author": "Racalvin The Pirate King",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "server": "node server/index.js",
    "server:dev": "node --watch server/index.js",
    "start": "npm run build && node server/index.js",
    "dev:full": "concurrently \"npm run dev\" \"npm run server:dev\""
  },
  "dependencies": {
    "@babylonjs/core": "^9.0.0",
    "@babylonjs/gui": "^9.0.0",
    "@babylonjs/loaders": "^9.0.0",
    "@babylonjs/materials": "^9.0.0",
    "@babylonjs/serializers": "^9.0.0",
    "@xterm/addon-attach": "^0.12.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "monaco-editor": "^0.55.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "node-pty": "^1.1.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
